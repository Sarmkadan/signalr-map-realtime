{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SignalRMapRealtimeDb;Trusted_Connection=true;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SignalRMapRealtime": "Information"
    },
    "Console": {
      "IncludeScopes": true,
      "Format": "json"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "ApiVersion": "1.0.0",
    "ApiTitle": "SignalR Map Realtime API",
    "Environment": "Production",
    "EnableSwagger": true,
    "EnableCors": true,
    "RequestTimeoutSeconds": 30,
    "LocationUpdateIntervalSeconds": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  }
}
