{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SignalRMapRealtimeDb;Trusted_Connection=true;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SignalRMapRealtime": "Information"
    },
    "Console": {
      "IncludeScopes": true,
      "Format": "json"
    }
  },
  "AllowedHosts": "*",

  "AppSettings": {
    "ApiVersion": "1.0.0",
    "ApiTitle": "SignalR Map Realtime API",
    "Environment": "Production",
    "EnableSwagger": true,
    "EnableCors": true,
    "RequestTimeoutSeconds": 30,
    "LocationUpdateIntervalSeconds": 30
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },

  "LocationThrottle": {
    "Enabled": true,
    "DeliveryVanIntervalSeconds": 1,
    "CourierIntervalSeconds": 10,
    "BicycleIntervalSeconds": 15,
    "MotorcycleIntervalSeconds": 5,
    "PortableIntervalSeconds": 30,
    "FixedAssetIntervalSeconds": 300,
    "DroneIntervalSeconds": 1
  },

  "SignalRMapRealtime": {
    "AppInfo": {
      "ApiVersion": "2.0.0",
      "ApiTitle": "SignalR Map Realtime API",
      "Environment": "Production",
      "EnableSwagger": true,
      "EnableCors": true,
      "RequestTimeoutSeconds": 30,
      "LocationUpdateIntervalSeconds": 30,
      "MaxPayloadSizeKb": 1024
    },

    "HealthChecks": {
      "Enabled": true,
      "TimeoutSeconds": 5,
      "MinimumStatus": "Healthy",
      "IncludeDetails": true
    },

    "ApiKeyAuthentication": {
      "Enabled": true,
      "HeaderName": "X-API-Key",
      "ApiKey": "your-api-key-here-change-in-production",
      "Required": true,
      "ExemptedEndpoints": [
        "/health",
        "/api/info",
        "/swagger",
        "/swagger/",
        "/swagger/v1/swagger.json"
      ]
    },

    "Performance": {
      "EnableDetailedMetrics": true,
      "MaxConcurrentConnections": 10000,
      "RequestQueueLimit": 1000,
      "EnableAdaptiveRateLimiting": false,
      "MaxProcessingTimeSeconds": 30,
      "EnableCaching": true
    },

    "SignalRHubs": {
      "Enabled": true,
      "MaxConnectionsPerHub": 10000,
      "UseBackplane": false,
      "BackplaneConnectionString": "localhost:6379",
      "EnableAutomaticReconnect": true,
      "ReconnectTimeoutSeconds": 30,
      "MaxMessageSizeKb": 256,
      "EnableMessageCompression": true
    },

    "WebSockets": {
      "Enabled": true,
      "KeepAliveIntervalSeconds": 30,
      "MaxMessageSizeKb": 256,
      "EnablePingPong": true,
      "PingIntervalSeconds": 30,
      "MaxConnectionDurationHours": 8
    },

    "BackgroundJobs": {
      "Enabled": true,
      "MaxConcurrentWorkers": 5,
      "SessionCleanupIntervalMinutes": 5,
      "EnableCacheCleanup": true,
      "CacheCleanupIntervalMinutes": 30,
      "EnableDatabaseMaintenance": true,
      "DatabaseMaintenanceIntervalHours": 24
    },

    "Security": {
      "EnableHttpsRedirection": true,
      "EnableRequestLogging": true,
      "EnableCorsSecurityHeaders": true,
      "EnableRateLimiting": true,
      "EnableInputValidation": true,
      "EnableSecurityHeaders": true,
      "ContentSecurityPolicy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },

  "Caching": {
    "Enabled": true,
    "DefaultDurationSeconds": 300,
    "LocationCacheDurationSeconds": 30,
    "VehicleCacheDurationSeconds": 600,
    "RouteCacheDurationSeconds": 1800,
    "AssetCacheDurationSeconds": 1800,
    "SessionCacheDurationSeconds": 600,
    "UseDistributedCache": false,
    "DistributedCacheConnectionString": "localhost:6379",
    "RefreshTokenAbsoluteExpirationMinutes": 1440,
    "SessionSlidingExpirationMinutes": 30,
    "MaxMemoryCacheEntries": 10000
  },

  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 60,
    "LocationUpdatesPerMinute": 120,
    "AuthenticationAttemptsPerMinute": 10,
    "ListEndpointsPerMinute": 40,
    "WebhookRequestsPerMinute": 30,
    "WindowSizeSeconds": 60,
    "EnableIpBasedLimiting": true,
    "EnableUserBasedLimiting": true,
    "ExemptedEndpoints": [
      "/health",
      "/api/info",
      "/swagger"
    ],
    "WhitelistedIps": [],
    "TooManyRequestsStatusCode": 429,
    "IncludeRateLimitHeaders": true,
    "UseDistributedRateLimiting": false,
    "DistributedCounterTtlSeconds": 120
  },

  "Notifications": {
    "Enabled": false,
    "Email": {
      "Enabled": false,
      "SmtpHost": "smtp.example.com",
      "SmtpPort": 587,
      "SmtpUsername": "",
      "SmtpPassword": "",
      "UsesTls": true,
      "FromAddress": "",
      "FromDisplayName": "SignalR Map Realtime",
      "TemplateDirectory": "/templates/email"
    },
    "Sms": {
      "Enabled": false,
      "ApiKey": "",
      "ApiSecret": "",
      "Provider": "Twilio",
      "SenderId": "",
      "CustomProviderUrl": ""
    },
    "Push": {
      "Enabled": false,
      "Provider": "Firebase",
      "FirebaseProjectId": "",
      "FirebaseCredentialsPath": "",
      "OneSignalAppId": "",
      "OneSignalApiKey": "",
      "TimeToLiveSeconds": 3600
    },
    "DefaultSender": "noreply@signalrmaptracking.com",
    "UseAsyncProcessing": true,
    "MaxRetries": 3,
    "RetryDelaySeconds": 5
  },

  "RoutePlayback": {
    "MaxConcurrentPlaybacks": 100,
    "DefaultSpeedMultiplier": 1.0,
    "MaxSpeedMultiplier": 64.0,
    "MinSpeedMultiplier": 0.1,
    "MinFrameIntervalMs": 50,
    "MaxFrameIntervalMs": 10000,
    "IdleSpeedThresholdKmh": 2.0,
    "IdleMinDurationSeconds": 60,
    "SpeedAlertThresholdKmh": 120.0,
    "MaxLocationsPerPlayback": 50000,
    "PlaybackSessionTimeoutMinutes": 30
  }
}